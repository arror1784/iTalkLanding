# Dependencies
/node_modules

# Build output
/dist

# Vercel
.vercel

# Vite & Environment Variables
# Ignore all .env files, but not .env.example
.env
.env.*
!.env.example

# Log files
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# IDE / Editor directories
.idea
.vscode

# OS generated files
.DS_Store
Thumbs.db